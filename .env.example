GEMINI_API_KEY=your_gemini_api_key_here

# LLM settings
GEMMA_MODEL=gemma-4-27b-it
EMBEDDING_MODEL=models/text-embedding-004
GEMMA_TEMPERATURE=0.2
GEMMA_MAX_TOKENS=4096

# RAG settings
CHUNK_SIZE=300
CHUNK_OVERLAP=40
TOP_K_RETRIEVAL=6
RERANK_TOP_K=3

# Vector store
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=meetings

# Redis cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
SIMILARITY_CACHE_THRESHOLD=0.92

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Whisper
WHISPER_MODEL=base
